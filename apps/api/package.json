{
  "name": "@devrelay/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "dotenv -e ../../.env -- tsc-watch -p tsconfig.build.json --onSuccess \"node dist/main.js\"",
    "lint": "eslint src",
    "qstash:schedule": "dotenv -e ../../.env -- tsx src/qstash-schedule.ts",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@devrelay/config": "workspace:*",
    "@devrelay/contracts": "workspace:*",
    "@devrelay/database": "workspace:*",
    "@devrelay/execution": "workspace:*",
    "@devrelay/monitoring": "workspace:*",
    "@devrelay/queue": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@opentelemetry/api": "1.9.1",
    "@upstash/qstash": "^2.8.4",
    "better-auth": "^1.6.23",
    "better-call": "1.3.7",
    "drizzle-orm": "0.45.2",
    "express": "^5.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "svix": "^1.97.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "dotenv-cli": "^11.0.0",
    "tsc-watch": "^7.2.1",
    "tsx": "^4.20.6",
    "vitest": "4.1.10"
  }
}
