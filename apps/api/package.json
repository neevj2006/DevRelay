{
  "name": "@devrelay/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "dotenv -e ../../.env -- tsc-watch -p tsconfig.build.json --onSuccess \"node dist/main.js\"",
    "lint": "eslint src",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@devrelay/config": "workspace:*",
    "@devrelay/contracts": "workspace:*",
    "@devrelay/database": "workspace:*",
    "@devrelay/monitoring": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "better-auth": "^1.6.23",
    "drizzle-orm": "0.45.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "tsc-watch": "^7.2.1",
    "tsx": "^4.20.6",
    "vitest": "4.1.10"
  }
}
