{
  "name": "@devrelay/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "lint": "eslint src",
    "start": "dotenv -e ../../.env -- tsx src/main.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@devrelay/config": "workspace:*"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.20.6",
    "vitest": "4.1.10"
  }
}
