NODE_ENV=development

# Local Docker Compose services. These values are development-only examples.
DATABASE_URL=postgresql://devrelay:devrelay_local@localhost:5432/devrelay
REDIS_URL=redis://localhost:6379
MAILPIT_SMTP_URL=smtp://localhost:1025
MAILPIT_HTTP_URL=http://localhost:8025

API_HOST=127.0.0.1
API_PORT=4000
APP_ORIGIN=http://localhost:3000
AUTH_BASE_URL=http://localhost:3000
# Local-only example. Production must use a unique secret with at least 32 characters.
AUTH_SECRET=devrelay-local-auth-secret-change-me
# Optional; configure both values to enable GitHub OAuth.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
WORKER_HEARTBEAT_INTERVAL_MS=30000
NEXT_PUBLIC_API_URL=http://localhost:4000
