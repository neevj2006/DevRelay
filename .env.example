NODE_ENV=development

# Local Docker Compose services. These values are development-only examples.
DATABASE_URL=postgresql://devrelay:devrelay_local@localhost:5432/devrelay
REDIS_URL=redis://localhost:6379
MAILPIT_SMTP_URL=smtp://localhost:1025
MAILPIT_HTTP_URL=http://localhost:8025

API_HOST=127.0.0.1
API_PORT=4000
API_BODY_LIMIT_BYTES=1048576
AUTH_BODY_LIMIT_BYTES=262144
PUBLIC_SSE_MAX_CONNECTIONS=100
TRUSTED_PROXY_CIDRS=
APP_ORIGIN=http://localhost:3000
AUTH_BASE_URL=http://localhost:3000
# Local-only example. Production must use a unique secret with at least 32 characters.
AUTH_SECRET=devrelay-local-auth-secret-change-me
# Optional; configure both values to enable GitHub OAuth.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
QUEUE_ADAPTER=bullmq
# Hosted QStash mode requires all three secrets. Keep the scheduler paused while configuring it.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_DELIVERY_BASE_URL=http://localhost:4000
QSTASH_HOSTED_SCHEDULER_PAUSED=true
QSTASH_DISPATCH_BATCH_SIZE=5
QSTASH_DAILY_MESSAGE_LIMIT=250
WORKER_HEARTBEAT_INTERVAL_MS=30000
NEXT_PUBLIC_API_URL=http://localhost:4000
CHECK_RESULT_RETENTION_DAYS=30
DELIVERY_ATTEMPT_RETENTION_DAYS=30
TOKEN_RETENTION_DAYS=7
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
EMAIL_FROM=DevRelay <notifications@localhost>
# Generate a random 32+ character value. Required before creating outgoing webhooks.
NOTIFICATION_ENCRYPTION_KEY=
# Optional hosted email configuration. When empty, the worker sends to Mailpit over SMTP.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
