{
  "name": "@devrelay/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:check": "pnpm --filter @devrelay/contracts build && drizzle-kit check",
    "db:generate": "pnpm --filter @devrelay/contracts build && drizzle-kit generate",
    "db:migrate": "pnpm --filter @devrelay/contracts build && drizzle-kit migrate",
    "db:studio": "pnpm --filter @devrelay/contracts build && drizzle-kit studio",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@devrelay/contracts": "workspace:*",
    "@opentelemetry/api": "1.9.1",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "vitest": "4.1.10"
  }
}
